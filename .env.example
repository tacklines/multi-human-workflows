# Docker Compose port mapping (change if defaults conflict)
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445
KRATOS_PUBLIC_PORT=4433
POSTGRES_PORT=5433

# Workspace OAuth (for Coder workspace → server auth)
# The seed-hydra-client.sh script registers this client in Hydra.
# Set this so WorkspaceTokenProvider can mint JWTs for workspaces.
WORKSPACE_CLIENT_SECRET=workspace-dev-secret

# Server URL (auto-rewritten to host.docker.internal for Docker workspaces)
SEAM_URL=http://localhost:3002
