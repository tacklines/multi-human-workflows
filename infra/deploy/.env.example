# =============================================================================
# Seam Production Environment Variables
# Copy to .env and fill in all values before deploying.
# =============================================================================

# -- Postgres -----------------------------------------------------------------
POSTGRES_DB=seam
POSTGRES_USER=seam
POSTGRES_PASSWORD=           # Strong random password

# -- RabbitMQ -----------------------------------------------------------------
RABBITMQ_DEFAULT_USER=seam
RABBITMQ_DEFAULT_PASS=       # Strong random password

# -- Ory Hydra (OAuth2/OIDC) -------------------------------------------------
HYDRA_SECRETS_SYSTEM=        # Random string for Hydra's system secret (min 16 chars)

# -- Ory Kratos (identity management) ---------------------------------------
KRATOS_SECRETS_COOKIE=       # Random string for Kratos cookie encryption
KRATOS_SECRETS_CIPHER=       # Random string for Kratos cipher encryption

# -- Seam Server --------------------------------------------------------------
SEAM_IMAGE=                  # ECR image URL, e.g. 123456789.dkr.ecr.us-east-1.amazonaws.com/seam:latest
CREDENTIAL_MASTER_KEY=       # Fernet key for credential encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MCP_AUTH_DISABLED=false      # Set to "true" only for initial setup/debugging

# -- Workspace OAuth (Coder workspace → server auth) -------------------------
WORKSPACE_CLIENT_SECRET=     # Shared secret for seam-workspace Hydra client (openssl rand -hex 32)
WORKSPACE_SEAM_URL=          # URL workspaces use to reach server (e.g. https://seam.tacklines.com)

# -- Seam Worker --------------------------------------------------------------
WORKER_API_TOKEN=            # Bearer token for worker-to-server API calls (random string)

# -- Coder (workspace orchestration) -----------------------------------------
CODER_TOKEN=                 # Coder API token (create via: coder tokens create --name seam-integration)
CODER_ACCESS_URL=            # Tailscale URL for Coder, e.g. https://coder.tailnet-name.ts.net

# -- Docker -------------------------------------------------------------------
DOCKER_GID=                  # Docker group ID on the host (run: getent group docker | cut -d: -f3)
