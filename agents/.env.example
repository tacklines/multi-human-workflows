# LLM — the router picks the best model per-request, these are fallback defaults
LLM_PROVIDER=ollama
DEFAULT_MODEL=qwen35-tuned

# Ollama (local models: qwen35-tuned, devstral-tuned)
OLLAMA_BASE_URL=http://192.168.1.14:11434

# Anthropic (set key to enable API models: opus, sonnet, haiku)
# ANTHROPIC_API_KEY=sk-ant-...

# Seam MCP
SEAM_MCP_BINARY=../server/target/debug/seam-mcp
DATABASE_URL=postgres://seam:seam@localhost:5432/seam

# Langfuse (self-hosted)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3101
